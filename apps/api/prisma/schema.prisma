generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AccessScope {
  ALL_COMPANIES
  COMPANY
  BRANCH
  OWN
}

enum ResetPolicy {
  NEVER
  YEARLY
  MONTHLY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESH
  TOKEN_REUSE
  APPROVE
  REJECT
  POST
  CANCEL
}

enum InventoryItemType {
  STOCK
  NON_STOCK
  SERVICE
}

enum StockMovementType {
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_OUT
  TRANSFER_IN
  SALES_OUT
  PURCHASE_IN
  RETURN_IN
  RETURN_OUT
}

enum StockMovementSourceType {
  ADJUSTMENT
  TRANSFER
  PURCHASE_RECEIPT
  SALES_DELIVERY
  OPENING_BALANCE
}

enum PriceListType {
  SALES
  PURCHASE
}

model Company {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String       @unique @db.VarChar(50)
  name             String       @db.VarChar(255)
  legalName        String?      @map("legal_name") @db.VarChar(255)
  taxNumber        String?      @map("tax_number") @db.VarChar(100)
  baseCurrencyCode String       @default("IDR") @map("base_currency_code") @db.Char(3)
  email            String?      @db.VarChar(255)
  phone            String?      @db.VarChar(50)
  address          String?
  status           RecordStatus @default(ACTIVE)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz(6)

  branches          Branch[]
  warehouses        Warehouse[]
  itemCategories    ItemCategory[]
  unitsOfMeasure    UnitOfMeasure[]
  inventoryItems    InventoryItem[]
  stockBalances     StockBalance[]
  stockMovements    StockMovement[]
  roles             Role[]
  userRoles         UserRole[]
  userCompanyAccess UserCompanyAccess[]
  documentSequences DocumentSequence[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  customers         Customer[]
  suppliers         Supplier[]
  priceLists        PriceList[]
  taxes             Tax[]
  paymentTerms      PaymentTerm[]
  paymentMethods    PaymentMethod[]
  bankAccounts      BankAccount[]
  chartOfAccounts   ChartOfAccount[]
  productAccountingMappings ProductAccountingMapping[]
  salesOrders               SalesOrder[]
  purchaseOrders            PurchaseOrder[]
  deliveryOrders            DeliveryOrder[]
  goodsReceipts             GoodsReceipt[]
  salesInvoices             SalesInvoice[]
  purchaseInvoices          PurchaseInvoice[]
  customerPayments          CustomerPayment[]
  supplierPayments          SupplierPayment[]
  salesReturns              SalesReturn[]
  purchaseReturns           PurchaseReturn[]
  journalEntries            JournalEntry[]
  landedCosts               LandedCost[]

  @@map("companies")
}

model Branch {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String       @map("company_id") @db.Uuid
  code      String       @db.VarChar(50)
  name      String       @db.VarChar(255)
  email     String?      @db.VarChar(255)
  phone     String?      @db.VarChar(50)
  address   String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(6)

  company           Company            @relation(fields: [companyId], references: [id])
  warehouses        Warehouse[]
  userBranchAccess  UserBranchAccess[]
  documentSequences DocumentSequence[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  salesOrders       SalesOrder[]
  purchaseOrders    PurchaseOrder[]
  deliveryOrders    DeliveryOrder[]
  goodsReceipts     GoodsReceipt[]
  salesInvoices     SalesInvoice[]
  purchaseInvoices  PurchaseInvoice[]
  customerPayments  CustomerPayment[]
  supplierPayments  SupplierPayment[]
  salesReturns      SalesReturn[]
  purchaseReturns   PurchaseReturn[]
  journalEntries    JournalEntry[]
  landedCosts       LandedCost[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([status])
  @@map("branches")
}

model Warehouse {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String       @map("company_id") @db.Uuid
  branchId  String?      @map("branch_id") @db.Uuid
  code      String       @db.VarChar(50)
  name      String       @db.VarChar(255)
  address   String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(6)

  company        Company         @relation(fields: [companyId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  stockBalances  StockBalance[]
  stockMovements StockMovement[]
  deliveryOrders DeliveryOrder[]
  goodsReceipts  GoodsReceipt[]
  salesReturns   SalesReturn[]
  purchaseReturns PurchaseReturn[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@map("warehouses")
}

model ItemCategory {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  parentId    String?      @map("parent_id") @db.Uuid
  code        String       @db.VarChar(50)
  name        String       @db.VarChar(255)
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)

  company  Company         @relation(fields: [companyId], references: [id])
  parent   ItemCategory?   @relation("ItemCategoryHierarchy", fields: [parentId], references: [id])
  children ItemCategory[]  @relation("ItemCategoryHierarchy")
  items    InventoryItem[]
  productAccountingMappings ProductAccountingMapping[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
  @@index([status])
  @@map("item_categories")
}

model UnitOfMeasure {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String       @map("company_id") @db.Uuid
  code          String       @db.VarChar(50)
  name          String       @db.VarChar(255)
  symbol        String       @db.VarChar(50)
  decimalPlaces Int          @default(0) @map("decimal_places")
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)

  company         Company              @relation(fields: [companyId], references: [id])
  baseItems       InventoryItem[]      @relation("InventoryItemBaseUnit")
  conversionsFrom    ItemUnitConversion[] @relation("ItemUnitConversionFromUnit")
  conversionsTo      ItemUnitConversion[] @relation("ItemUnitConversionToUnit")
  salesOrderItems      SalesOrderItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  priceListItems       PriceListItem[]
  deliveryOrderItems    DeliveryOrderItem[]
  goodsReceiptItems     GoodsReceiptItem[]
  salesInvoiceItems    SalesInvoiceItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  salesReturnItems     SalesReturnItem[]
  purchaseReturnItems  PurchaseReturnItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([status])
  @@map("units_of_measure")
}

model InventoryItem {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String            @map("company_id") @db.Uuid
  categoryId     String?           @map("category_id") @db.Uuid
  baseUnitId     String            @map("base_unit_id") @db.Uuid
  sku            String            @db.VarChar(100)
  name           String            @db.VarChar(255)
  description    String?
  barcode        String?           @db.VarChar(100)
  itemType       InventoryItemType @default(STOCK) @map("item_type")
  trackInventory Boolean           @default(true) @map("track_inventory")
  isSellable     Boolean           @default(true) @map("is_sellable")
  isPurchasable  Boolean           @default(true) @map("is_purchasable")
  minStock       Decimal?          @map("min_stock") @db.Decimal(19, 4)
  status         RecordStatus      @default(ACTIVE)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?         @map("deleted_at") @db.Timestamptz(6)

  company        Company              @relation(fields: [companyId], references: [id])
  category       ItemCategory?        @relation(fields: [categoryId], references: [id])
  baseUnit       UnitOfMeasure        @relation("InventoryItemBaseUnit", fields: [baseUnitId], references: [id])
  conversions    ItemUnitConversion[]
  stockBalances  StockBalance[]
  stockMovements StockMovement[]
  priceListItems   PriceListItem[]
  productAccountingMappings ProductAccountingMapping[]
  salesOrderItems     SalesOrderItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  deliveryOrderItems   DeliveryOrderItem[]
  goodsReceiptItems    GoodsReceiptItem[]
  salesInvoiceItems    SalesInvoiceItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  salesReturnItems     SalesReturnItem[]
  purchaseReturnItems  PurchaseReturnItem[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([categoryId])
  @@index([baseUnitId])
  @@index([itemType])
  @@index([status])
  @@map("inventory_items")
}

model ItemUnitConversion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId     String   @map("item_id") @db.Uuid
  fromUnitId String   @map("from_unit_id") @db.Uuid
  toUnitId   String   @map("to_unit_id") @db.Uuid
  factor     Decimal  @db.Decimal(19, 6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  item     InventoryItem @relation(fields: [itemId], references: [id])
  fromUnit UnitOfMeasure @relation("ItemUnitConversionFromUnit", fields: [fromUnitId], references: [id])
  toUnit   UnitOfMeasure @relation("ItemUnitConversionToUnit", fields: [toUnitId], references: [id])

  @@unique([itemId, fromUnitId, toUnitId])
  @@index([itemId])
  @@index([fromUnitId])
  @@index([toUnitId])
  @@map("item_unit_conversions")
}

model StockBalance {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  itemId      String   @map("item_id") @db.Uuid
  quantity    Decimal  @default(0) @db.Decimal(19, 4)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  company   Company       @relation(fields: [companyId], references: [id])
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  item      InventoryItem @relation(fields: [itemId], references: [id])

  @@unique([companyId, warehouseId, itemId])
  @@index([companyId])
  @@index([warehouseId])
  @@index([itemId])
  @@map("stock_balances")
}

model StockMovement {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String                  @map("company_id") @db.Uuid
  warehouseId  String                  @map("warehouse_id") @db.Uuid
  itemId       String                  @map("item_id") @db.Uuid
  movementType StockMovementType       @map("movement_type")
  sourceType   StockMovementSourceType @map("source_type")
  sourceId     String?                 @map("source_id") @db.Uuid
  quantity     Decimal                 @db.Decimal(19, 4)
  balanceAfter Decimal                 @map("balance_after") @db.Decimal(19, 4)
  notes        String?
  createdById  String?                 @map("created_by_id") @db.Uuid
  occurredAt   DateTime                @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  company   Company       @relation(fields: [companyId], references: [id])
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  item      InventoryItem @relation(fields: [itemId], references: [id])
  createdBy User?         @relation("StockMovementCreatedBy", fields: [createdById], references: [id])

  @@index([companyId])
  @@index([warehouseId])
  @@index([itemId])
  @@index([sourceType, sourceId])
  @@index([occurredAt])
  @@map("stock_movements")
}

model User {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String       @unique @db.VarChar(255)
  passwordHash String       @map("password_hash") @db.VarChar(255)
  fullName     String       @map("full_name") @db.VarChar(255)
  phone        String?      @db.VarChar(50)
  status       RecordStatus @default(ACTIVE)
  lastLoginAt  DateTime?    @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz(6)

  roles               UserRole[]
  companyAccess       UserCompanyAccess[]
  branchAccess        UserBranchAccess[]
  authSessions        AuthSession[]
  uploadedAttachments Attachment[]        @relation("AttachmentUploadedBy")
  auditLogs           AuditLog[]          @relation("AuditActor")
  stockMovements      StockMovement[]     @relation("StockMovementCreatedBy")

  @@index([status])
  @@map("users")
}

model AuthSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(255)
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address") @db.VarChar(100)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  compromisedAt    DateTime? @map("compromised_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User               @relation(fields: [userId], references: [id])
  refreshTokens AuthRefreshToken[]

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([compromisedAt])
  @@map("auth_sessions")
}

model AuthRefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String    @map("session_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  session AuthSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([revokedAt])
  @@map("auth_refresh_tokens")
}

model Role {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String?   @map("company_id") @db.Uuid
  code        String    @db.VarChar(100)
  name        String    @db.VarChar(255)
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company     Company?         @relation(fields: [companyId], references: [id])
  users       UserRole[]
  permissions RolePermission[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module      String   @db.VarChar(100)
  action      String   @db.VarChar(100)
  code        String   @unique @db.VarChar(200)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  companyId String?  @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User     @relation(fields: [userId], references: [id])
  role    Role     @relation(fields: [roleId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@unique([userId, roleId, companyId])
  @@index([userId])
  @@index([roleId])
  @@index([companyId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserCompanyAccess {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  accessScope AccessScope @map("access_scope")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("user_company_access")
}

model UserBranchAccess {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  branchId    String      @map("branch_id") @db.Uuid
  accessScope AccessScope @map("access_scope")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
  @@map("user_branch_access")
}

model DocumentSequence {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String      @map("company_id") @db.Uuid
  branchId     String?     @map("branch_id") @db.Uuid
  documentType String      @map("document_type") @db.VarChar(100)
  prefix       String      @db.VarChar(100)
  periodFormat String      @map("period_format") @db.VarChar(50)
  lastPeriod   String?     @map("last_period") @db.VarChar(50)
  nextNumber   Int         @default(1) @map("next_number")
  padding      Int         @default(5)
  resetPolicy  ResetPolicy @default(MONTHLY) @map("reset_policy")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch? @relation(fields: [branchId], references: [id])

  @@unique([companyId, branchId, documentType, periodFormat])
  @@index([companyId])
  @@index([branchId])
  @@map("document_sequences")
}

model Attachment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  branchId     String?   @map("branch_id") @db.Uuid
  entityType   String    @map("entity_type") @db.VarChar(100)
  entityId     String    @map("entity_id") @db.Uuid
  bucket       String    @db.VarChar(100)
  objectPath   String    @map("object_path")
  originalName String    @map("original_name") @db.VarChar(255)
  mimeType     String    @map("mime_type") @db.VarChar(255)
  sizeBytes    BigInt    @map("size_bytes")
  checksum     String?   @db.VarChar(255)
  uploadedById String?   @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  company    Company @relation(fields: [companyId], references: [id])
  branch     Branch? @relation(fields: [branchId], references: [id])
  uploadedBy User?   @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([companyId])
  @@index([branchId])
  @@index([entityType, entityId])
  @@map("attachments")
}

model AuditLog {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String?     @map("company_id") @db.Uuid
  branchId    String?     @map("branch_id") @db.Uuid
  actorUserId String?     @map("actor_user_id") @db.Uuid
  action      AuditAction
  entityType  String      @map("entity_type") @db.VarChar(100)
  entityId    String?     @map("entity_id") @db.Uuid
  oldValues   Json?       @map("old_values")
  newValues   Json?       @map("new_values")
  ipAddress   String?     @map("ip_address") @db.VarChar(100)
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company? @relation(fields: [companyId], references: [id])
  branch  Branch?  @relation(fields: [branchId], references: [id])
  actor   User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([companyId])
  @@index([branchId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Customer {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  code        String       @db.VarChar(50)
  name        String       @db.VarChar(255)
  phone       String?      @db.VarChar(50)
  email       String?      @db.VarChar(255)
  address     String?
  taxNumber   String?      @map("tax_number") @db.VarChar(100)
  creditLimit Decimal?     @map("credit_limit") @db.Decimal(19, 4)
  paymentTerm String?      @map("payment_term") @db.VarChar(50)
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)

